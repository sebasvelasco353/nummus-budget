# ──────────────────────────────────────────
# Backend — Development
# TypeScript with tsx watch for live reload
# ──────────────────────────────────────────
FROM node:22-alpine

WORKDIR /app

# Copy workspace manifests for dependency installation
COPY package.json package-lock.json* ./
COPY apps/frontend/package.json ./apps/frontend/
COPY apps/backend/package.json  ./apps/backend/

RUN npm install

# Copy full backend source so tsx can resolve modules at startup
# (src/ will be overridden by the bind mount in compose.dev.yml)
COPY apps/backend ./apps/backend

WORKDIR /app/apps/backend

EXPOSE 3000

CMD ["npx", "tsx", "watch", "--tsconfig", "tsconfig.json", "src/server.ts"]