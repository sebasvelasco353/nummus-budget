# ──────────────────────────────────────────
# Backend — Development
# nodemon + tsx for TypeScript live reload
# ──────────────────────────────────────────
FROM node:24-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
COPY apps/frontend/package.json ./apps/frontend/
COPY apps/backend/package.json  ./apps/backend/

RUN npm install

# Copy full backend so nodemon.json, tsconfig.json etc. are present
COPY apps/backend ./apps/backend

WORKDIR /app/apps/backend

EXPOSE 3000

CMD ["npx", "nodemon"]