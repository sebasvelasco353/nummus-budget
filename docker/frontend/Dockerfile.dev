# ──────────────────────────────────────────
# Frontend — Development
# Vite dev server with HMR via bind mount
# ──────────────────────────────────────────
FROM node:22-alpine

WORKDIR /app

# Copy workspace manifests first for better layer caching.
# We need the root package.json (workspaces config) and both
# app manifests so `npm install` resolves the full workspace.
COPY package.json package-lock.json* ./
COPY apps/frontend/package.json ./apps/frontend/
COPY apps/backend/package.json  ./apps/backend/

# Install all workspace deps at the repo root
RUN npm install

WORKDIR /app/apps/frontend

EXPOSE 5173

CMD ["npm", "run", "dev"]