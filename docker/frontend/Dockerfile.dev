# ──────────────────────────────────────────
# Frontend — Development
# Vite dev server with HMR via bind mount
# ──────────────────────────────────────────
FROM node:24-alpine

WORKDIR /app

# Copy workspace manifests for dependency installation
COPY package.json package-lock.json* ./
COPY apps/frontend/package.json ./apps/frontend/
COPY apps/backend/package.json  ./apps/backend/

RUN npm install

# Copy full frontend source so vite.config.js and other config
# files are present at startup (src/ is overridden by bind mount)
COPY apps/frontend ./apps/frontend

WORKDIR /app/apps/frontend

EXPOSE 5173

CMD ["npm", "run", "dev"]