{
  "name": "nummus-budget",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose -f compose.base.yml -f compose.dev.yml up -d --build",
    "dev:down": "docker compose -f compose.base.yml -f compose.dev.yml down",
    "prod": "docker compose -f compose.base.yml -f compose.prod.yml up --build -d",
    "prod:down": "docker compose -f compose.base.yml -f compose.prod.yml down",
    "logs": "docker compose -f compose.base.yml -f compose.dev.yml logs -f",
    "db:generate": "npm run -w apps/backend db:generate",
    "db:push": "npm run -w apps/backend db:push",
    "db:migrate": "npm run -w apps/backend db:migrate",
    "db:studio": "npm run -w apps/backend db:studio"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript-eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint"
    ]
  }
}
